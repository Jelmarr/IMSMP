generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String              @id @default(uuid())
  username                String              @unique
  role                    Role
  email                   String              @unique
  password                String
  firstName               String              @default("N/A")
  lastName                String              @default("N/A")
  middleName              String?
  profileImage            String?
  otp                     String?
  otpExpiresAt            DateTime?
  createdAt               DateTime            @default(now())
  status                  UserStatus          @default(ACTIVE)
  bannedReason            String?
  bannedAt                DateTime?
  mustChangePassword      Boolean             @default(true)
  lastSeen                DateTime            @default(now()) @updatedAt
  isOnline                Boolean             @default(false)
  AuditLog                AuditLog[]
  medTechRequestsApproved MedTechRequest[]    @relation("MedTechApprovedBy")
  archivedMedTechRequests MedTechRequest[]    @relation("ArchivedMedTechRequests")
  medTechRequestsReceived MedTechRequest[]    @relation("MedTechReceivedBy")
  medTechRequestsCreated  MedTechRequest[]    @relation("MedTechRequestedBy")
  ReceivedNotification    Notification[]      @relation("ReceivedNotification")
  SentNotification        Notification[]      @relation("SentNotification")
  ArchivedOrderRequests   OrderRequest[]      @relation("ArchivedOrderRequests")
  DispensedOrders         OrderRequest[]      @relation("DispensedBy")
  PreparedOrders          OrderRequest[]      @relation("PreparedBy")
  ReceivedOrders          OrderRequest[]      @relation("ReceivedBy")
  OrderRequest            OrderRequest[]      @relation("RequestedBy")
  paymentsProcessed       Payment[]           @relation("PaymentProcessedBy")
  ArchivedProducts        Product[]           @relation("ArchivedProducts")
  Product                 Product[]
  ArchivedBatches         ProductBatch[]      @relation("ArchivedBatches")
  refundsProcessed        Refund[]            @relation("RefundProcessedBy")
  WalkInTransaction       WalkInTransaction[]
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      String
  action      String
  entityType  String
  entityId    Int?
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Product {
  id                   Int                  @id @default(autoincrement())
  product_name         String
  status               String               @default("ACTIVE")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  categoryId           Int?
  genericName          String?
  manufacturer         String?
  description          String?
  strength             String?
  dosageForm           String?
  requiresPrescription Boolean              @default(false)
  price                Decimal
  minimumStockAlert    Decimal              @default(6)
  archivedById         String?
  archiveAt            DateTime?
  archiveReason        String?
  userId               String?
  medTechRequestItems  MedTechRequestItem[]
  Notification         Notification[]
  orderItems           OrderItem[]
  archivedByUser       User?                @relation("ArchivedProducts", fields: [archivedById], references: [id])
  category             ProductCategory?     @relation(fields: [categoryId], references: [id])
  user                 User?                @relation(fields: [userId], references: [id])
  batches              ProductBatch[]
  WalkInItem           WalkInItem[]
}

model ProductBatch {
  id              Int       @id @default(autoincrement())
  productId       Int
  archiveAt       DateTime?
  archiveReason   String?
  archivedById    String?
  batchNumber     String
  quantity        Int       @default(0)
  manufactureDate DateTime
  expiryDate      DateTime
  type            String    @default("ACTIVE")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archivedByUser  User?     @relation("ArchivedBatches", fields: [archivedById], references: [id])
  product         Product   @relation(fields: [productId], references: [id])
}

model ProductCategory {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model MedTechRequest {
  id             Int                  @id @default(autoincrement())
  notes          String?
  status         MedTechStatus        @default(pending_for_approval)
  remarks        MedTechRemarks       @default(processing)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  requestedById  String
  receivedById   String?
  receivedAt     DateTime?
  approvedById   String?
  approvedAt     DateTime?
  archivedById   String?
  isArchived     Boolean              @default(false)
  archiveReason  String?
  approvedBy     User?                @relation("MedTechApprovedBy", fields: [approvedById], references: [id])
  archivedByUser User?                @relation("ArchivedMedTechRequests", fields: [archivedById], references: [id])
  receivedBy     User?                @relation("MedTechReceivedBy", fields: [receivedById], references: [id])
  requestedBy    User                 @relation("MedTechRequestedBy", fields: [requestedById], references: [id])
  items          MedTechRequestItem[]
  Notification   Notification[]
  orderRequests  OrderRequest[]       @relation("MedTechOrderRequests")
}

model MedTechRequestItem {
  id               Int            @id @default(autoincrement())
  quantityOrdered  Decimal
  totalPrice       Decimal
  medTechRequestId Int
  productId        Int
  medTechRequest   MedTechRequest @relation(fields: [medTechRequestId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id])
}

model Patient {
  id            String         @id @default(cuid())
  patientNumber Int            @unique @default(autoincrement())
  patientName   String
  roomNumber    Int?
  contactNumber String?
  updatedAt     DateTime       @updatedAt
  createdAt     DateTime       @default(now())
  orderRequest  OrderRequest[]

  @@index([patientName])
}

model Payment {
  id              Int                @id @default(autoincrement())
  orderRequestId  Int?
  walkInOrderId   Int?
  subTotal        Decimal
  discountAmount  Decimal            @default(0)
  discountPercent Decimal            @default(0)
  discountType    DiscountType       @default(NONE)
  vatRate         Decimal            @default(12)
  vatAmount       Decimal
  vatExempt       Decimal            @default(0)
  zeroRated       Decimal            @default(0)
  amountDue       Decimal
  amountTendered  Decimal
  change          Decimal            @default(0)
  processedById   String
  createdAt       DateTime           @default(now())
  orderRequest    OrderRequest?      @relation(fields: [orderRequestId], references: [id], onDelete: Cascade)
  processedBy     User               @relation("PaymentProcessedBy", fields: [processedById], references: [id])
  walkInOrder     WalkInTransaction? @relation(fields: [walkInOrderId], references: [id], onDelete: Cascade)

  @@index([orderRequestId])
  @@index([walkInOrderId])
}

model Refund {
  id             Int                @id @default(autoincrement())
  orderRequestId Int?
  walkInOrderId  Int?
  refundAmount   Decimal
  refundReason   String
  refundedById   String
  refundedAt     DateTime           @default(now())
  orderRequest   OrderRequest?      @relation(fields: [orderRequestId], references: [id], onDelete: Cascade)
  refundedBy     User               @relation("RefundProcessedBy", fields: [refundedById], references: [id])
  walkInOrder    WalkInTransaction? @relation(fields: [walkInOrderId], references: [id], onDelete: Cascade)

  @@index([orderRequestId])
  @@index([walkInOrderId])
}

model OrderRequest {
  id               Int             @id @default(autoincrement())
  patientId        String
  status           Status
  remarks          Remarks         @default(preparing)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  totalAmount      Decimal
  type             OrderType       @default(REGULAR)
  medTechRequestId Int?
  archivedById     String?
  isArchived       Boolean         @default(false)
  archiveReason    String?
  userId           String
  receivedById     String?
  receivedAt       DateTime?
  preparedById     String?
  dispensedById    String?
  preparedAt       DateTime?
  dispensedAt      DateTime?
  Notification     Notification[]
  items            OrderItem[]
  archivedByUser   User?           @relation("ArchivedOrderRequests", fields: [archivedById], references: [id])
  dispensedBy      User?           @relation("DispensedBy", fields: [dispensedById], references: [id])
  medTechRequest   MedTechRequest? @relation("MedTechOrderRequests", fields: [medTechRequestId], references: [id])
  patient          Patient         @relation(fields: [patientId], references: [id])
  preparedBy       User?           @relation("PreparedBy", fields: [preparedById], references: [id])
  receivedBy       User?           @relation("ReceivedBy", fields: [receivedById], references: [id])
  user             User            @relation("RequestedBy", fields: [userId], references: [id])
  payments         Payment[]
  refunds          Refund[]
}

model OrderItem {
  id               Int          @id @default(autoincrement())
  refundedQuantity Decimal
  orderId          Int
  productId        Int
  quantityOrdered  Decimal
  price            Decimal
  totalPrice       Decimal
  order            OrderRequest @relation(fields: [orderId], references: [id])
  product          Product      @relation(fields: [productId], references: [id])
}

model WalkInTransaction {
  id            Int            @id @default(autoincrement())
  customer_name String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  status        Status
  totalAmount   Decimal        @default(0.00)
  userId        String
  Notification  Notification[]
  payments      Payment[]
  refunds       Refund[]
  items         WalkInItem[]
  user          User           @relation(fields: [userId], references: [id])
}

model WalkInItem {
  id               Int               @id @default(autoincrement())
  quantity         Int
  refundedQuantity Int               @default(0)
  price            Decimal
  total            Decimal
  productId        Int
  transactionId    Int
  product          Product           @relation(fields: [productId], references: [id])
  transaction      WalkInTransaction @relation(fields: [transactionId], references: [id])
}

model Notification {
  id               Int                @id @default(autoincrement())
  title            String
  read             Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  senderId         String
  recipientId      String
  orderId          Int?
  walkInOrderId    Int?
  medTechRequestId Int?
  productId        Int?
  type             NotificationType?
  patientName      String?
  roomNumber       String?
  submittedBy      String?
  role             String?
  medTechRequest   MedTechRequest?    @relation(fields: [medTechRequestId], references: [id])
  order            OrderRequest?      @relation(fields: [orderId], references: [id])
  product          Product?           @relation(fields: [productId], references: [id])
  recipient        User               @relation("ReceivedNotification", fields: [recipientId], references: [id])
  sender           User               @relation("SentNotification", fields: [senderId], references: [id])
  walkInOrder      WalkInTransaction? @relation(fields: [walkInOrderId], references: [id])
}

enum Role {
  SuperAdmin
  MedTech
  Pharmacist_Staff
  Nurse
  Manager
  Cashier
}

enum UserStatus {
  ACTIVE
  DISABLE
}

enum MedTechStatus {
  pending_for_approval
  approved
  declined
}

enum MedTechRemarks {
  processing
  ready
  released
}

enum DiscountType {
  NONE
  SENIOR
  PWD
  CUSTOM
}

enum Remarks {
  preparing
  prepared
  dispensed
}

enum OrderType {
  REGULAR
  EMERGENCY
}

enum Status {
  pending
  for_payment
  paid
  canceled
  refunded
}

enum NotificationType {
  MEDTECH_REQUEST
  MEDTECH_REQUEST_EDIT
  MT_REQUEST_READY
  MT_REQUEST_RELEASED
  MT_REQUEST_APPROVED
  MT_REQUEST_DECLINED
  ORDER_REQUEST
  ADD_PRODUCT
  ORDER_RECEIVED
  PAYMENT_PROCESSED
  EMERGENCY_ORDER
  REMARKS
  WALK_IN
}
